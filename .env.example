# Copy this file to .env.local and fill in your values

# Database — SQLite (local dev, zero setup)
DATABASE_URL="file:./dev.db"

# For PostgreSQL (production on Neon.tech / Supabase / Railway):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/automart?schema=public"

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_THIS_TO_A_RANDOM_SECRET_MIN_32_CHARS"
NEXTAUTH_URL="http://localhost:3000"

# Public site URL (used in generateMetadata for production)
# Set this to your production domain, e.g. https://automart.al
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Admin credentials (used by seed script)
ADMIN_EMAIL="admin@automart.al"
ADMIN_PASSWORD="Admin@1234"
